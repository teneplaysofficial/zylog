{
  "name": "zylog",
  "displayName": "Zylog",
  "version": "0.0.0",
  "description": "A simple and powerful logger for Node.js",
  "keywords": [
    "logger",
    "logging",
    "node-logger",
    "log-levels",
    "structured-logging",
    "log-streams",
    "file-logger",
    "debug",
    "monitoring",
    "cli",
    "devtools"
  ],
  "homepage": "https://teneplaysofficial.github.io/zylog",
  "repository": "git+https://github.com/teneplaysofficial/zylog.git",
  "bugs": "https://github.com/teneplaysofficial/zylog/issues",
  "funding": "https://github.com/sponsors/teneplaysofficial",
  "license": "Apache-2.0",
  "author": "Sriman",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "packageManager": "pnpm@10.32.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.cts",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "prepare": "husky",
    "prepublishOnly": "pnpm run test && pnpm run build",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "js-utils-kit": "^2.2.0",
    "use-colors": "^0.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tenedev/prettier-config": "^1.2.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "echo-banner": "^0.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "prettier": "@tenedev/prettier-config",
  "lint-staged": {
    "*": "prettier --write --ignore-unknown",
    "*.{js,ts}": "pnpm run lint:fix"
  }
}
